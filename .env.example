# ===== Database =====
# Local Postgres via docker-compose
DATABASE_URL="postgresql://hanyang:CHANGE_ME_STRONG_PW@localhost:5432/hanyang_ops?schema=public"

# ===== NextAuth (Auth.js) =====
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_RUN_OPENSSL_RAND_BASE64_32"
NEXTAUTH_URL="http://localhost:3000"

# ===== App =====
NODE_ENV="development"
APP_TIMEZONE="Asia/Seoul"

# ===== Email (SMTP) - free for MVP =====
# Use company email server, or Gmail App Password, or Brevo/Resend free tier
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-account@example.com"
SMTP_PASSWORD="app-password-here"
SMTP_FROM="한양유화 주문시스템 <noreply@hanyangpetro.com>"

# ===== Telegram (free, for internal alerts) =====
# Create bot via @BotFather, get token. Add bot to a group, get chat_id.
# Leave blank to disable.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_INTERNAL_CHAT_ID=""

# ===== KakaoTalk Alimtalk (PAID, 2nd phase) =====
# Provider: CoolSMS / NHN Toast / Aligo / etc.
# Leave blank in MVP.
KAKAO_ALIMTALK_PROVIDER=""
KAKAO_ALIMTALK_API_KEY=""
KAKAO_ALIMTALK_API_SECRET=""
KAKAO_ALIMTALK_SENDER_KEY=""

# ===== ERP automation =====
# Path on the office PC where existing Python scripts live
ERP_AUTOMATION_DIR="C:\\automation\\erp"
ERP_EXPORT_DIR="C:\\automation\\erp\\inbox"

# ===== Feature flags =====
ENABLE_CUSTOMER_PORTAL="false"
ENABLE_AUTO_RECEIPT_ASSUMPTION="false"
AUTO_RECEIPT_ASSUMPTION_DAYS="2"

# ===== Hanwha e-Sales =====
# 사무실 Windows PC의 한화솔루션 e-Sales 바로가기 경로
HANWHA_ESALES_SHORTCUT_PATH="C:\\Users\\Owner\\Desktop\\한화솔루션 e-Sales.lnk"

# ===== Hanwha H-CRM =====
# 비밀번호는 첫 실행 후 /admin/settings/hanwha 에서 DB로 저장 가능 (대표/관리자만)
HANWHA_LOGIN_URL="https://h-crm.my.site.com/order"
HANWHA_USERNAME=""
HANWHA_PASSWORD=""
HANWHA_HEADLESS="true"
